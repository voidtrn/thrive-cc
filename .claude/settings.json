{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"/home/user/thrive-cc/.claude/hooks/rtk-ensure.sh\"",
            "timeout": 15,
            "statusMessage": "Ensuring rtk binary..."
          },
          {
            "type": "command",
            "command": "node \"/home/user/thrive-cc/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          },
          {
            "type": "command",
            "command": "sh \"/home/user/thrive-cc/.claude/hooks/statusline-ensure.sh\"",
            "timeout": 10,
            "statusMessage": "Ensuring statusline badge..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/thrive-cc/.claude/hooks/caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/root/.local/bin/rtk hook claude"
          }
        ]
      }
    ]
  }
}
